# =============================================================================
#  Open Scheduler — environment configuration
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored — your secrets never get committed.
#
# WITHOUT Google credentials the app runs in DEMO mode: availability is
# simulated and bookings are faked (no real calendar event is created).
# Fill in the Google block below to switch to real Google Calendar sync.
# =============================================================================

# ---- Host (the person being booked) — safe to expose to the browser --------
NEXT_PUBLIC_HOST_NAME="Jarod Gabriel M."
NEXT_PUBLIC_HOST_INITIALS="JM"
NEXT_PUBLIC_HOST_TAGLINE="I’m listening."
# Allow weekend bookings (true/false). Default false = weekdays only.
NEXT_PUBLIC_ALLOW_WEEKENDS="false"

# ---- Conferencing ----------------------------------------------------------
# Which options the booker can pick (comma-separated, first is the default).
#   "meet"  — auto-generates a Google Meet link
#   "zoom"  — uses ZOOM_MEETING_URL
#   "phone" — no video link (e.g. a phone call; put the number in the note below)
# Examples: "meet" (default), "zoom", "meet,zoom", or "phone,zoom" (phone default,
# Zoom optional).
NEXT_PUBLIC_MEETING_OPTIONS="meet"
# Your fixed Zoom link (e.g. Personal Meeting Room) — required if "zoom" is offered.
ZOOM_MEETING_URL=""

# Restrict which lengths this page offers (comma-separated: 15,30,60,custom).
# Empty = all four. e.g. "15" for a 15-minute-only page.
NEXT_PUBLIC_DURATIONS=""
# A custom message shown on the booking page and added to the invite (e.g. call
# instructions / phone number). Plain text; line breaks are preserved.
NEXT_PUBLIC_BOOKING_NOTE=""

# Optional "event types" (Calendly-style): the booker first picks a type, which
# decides the lengths offered and the conferencing used. JSON array; leave unset
# for a single flow. Example — a 15-min Zoom "Student" type + a Meet "Professional"
# type with all lengths:
# NEXT_PUBLIC_EVENT_TYPES=[{"key":"student","label":"Student","durations":[15],"conferencing":"zoom"},{"key":"professional","label":"Professional","durations":[15,30,60,"custom"],"conferencing":"meet"}]
NEXT_PUBLIC_EVENT_TYPES=""

# ---- Host availability (server-side) ---------------------------------------
# IANA time zone the host's working hours are defined in.
HOST_TIMEZONE="America/Los_Angeles"
# Working-hours window, 24h clock, in HOST_TIMEZONE.
WORK_START_HOUR="9"
WORK_END_HOUR="17"
# Minimum lead time in whole calendar days (host tz). 0 = same-day bookings
# allowed; 1 = no same-day, earliest is tomorrow; 2 = earliest is two days out.
MIN_NOTICE_DAYS="0"
# Which calendar new bookings are CREATED on.
HOST_CALENDAR_ID="primary"
# Extra calendars to also check for conflicts (comma-separated calendar IDs).
# A busy block on ANY of these — plus HOST_CALENDAR_ID — removes that slot, so
# work/health/side-project calendars can't get double-booked. Each must be
# visible to the connected Google account (shared in with at least free/busy
# access). Find an ID in Google Calendar → calendar Settings → "Integrate
# calendar" → Calendar ID. Leave blank to only check HOST_CALENDAR_ID.
HOST_BUSY_CALENDAR_IDS=""

# ---- Google Calendar OAuth (leave blank to stay in demo mode) --------------
# Create an OAuth 2.0 "Web application" client in Google Cloud Console and
# enable the Google Calendar API. See README "Connecting Google Calendar".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must exactly match an Authorized redirect URI on the OAuth client.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# Obtained once via the /api/auth/google flow (see README). Long-lived.
GOOGLE_REFRESH_TOKEN=""
