# =============================================================================
#  Open Scheduler — environment configuration
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored — your secrets never get committed.
#
# WITHOUT Google credentials the app runs in DEMO mode: availability is
# simulated and bookings are faked (no real calendar event is created).
# Fill in the Google block below to switch to real Google Calendar sync.
# =============================================================================

# ---- Host (the person being booked) — safe to expose to the browser --------
NEXT_PUBLIC_HOST_NAME="Jarod Gabriel M."
NEXT_PUBLIC_HOST_INITIALS="JM"
NEXT_PUBLIC_HOST_TAGLINE="I’m listening."
# Allow weekend bookings (true/false). Default false = weekdays only.
NEXT_PUBLIC_ALLOW_WEEKENDS="false"

# ---- Host availability (server-side) ---------------------------------------
# IANA time zone the host's working hours are defined in.
HOST_TIMEZONE="America/Los_Angeles"
# Working-hours window, 24h clock, in HOST_TIMEZONE.
WORK_START_HOUR="9"
WORK_END_HOUR="17"
# Which calendar to read free/busy from and create events on.
HOST_CALENDAR_ID="primary"

# ---- Google Calendar OAuth (leave blank to stay in demo mode) --------------
# Create an OAuth 2.0 "Web application" client in Google Cloud Console and
# enable the Google Calendar API. See README "Connecting Google Calendar".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must exactly match an Authorized redirect URI on the OAuth client.
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# Obtained once via the /api/auth/google flow (see README). Long-lived.
GOOGLE_REFRESH_TOKEN=""
